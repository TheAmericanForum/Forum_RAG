# Copy to .env for local dev (and set the same as Heroku config vars in production).

# Which tenant/brand this deployment serves. Picks branding/<tenant>/ (logo, favicon,
# theme.css, brand.yaml). One codebase, one Heroku app per tenant. Defaults to "sc".
TENANT=sc

# LLM + embeddings
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Qdrant. If QDRANT_URL is set, the hosted cluster is used (required on Heroku).
# If unset, an embedded on-disk Qdrant at qdrant.local_path is used (LOCAL DEV ONLY —
# it does NOT persist on Heroku's ephemeral filesystem).
QDRANT_URL=
QDRANT_API_KEY=
# Collection name. Overrides qdrant.collection in config.yaml — set a distinct value
# per tenant so the deployments don't share one collection. Defaults to config.yaml.
QDRANT_COLLECTION=

# Google Drive ingestion (service account).
# Paste the ENTIRE service-account key JSON as a single-line value (no file on disk).
GOOGLE_SERVICE_ACCOUNT_JSON=
# Comma-separated Drive folder IDs to ingest (recursively).
DRIVE_FOLDER_IDS=

# Logging verbosity: DEBUG, INFO (default), WARNING, ERROR.
# Console + rotating file (./logs/sc_rag.log).
LOG_LEVEL=

# Google SSO login. Create OAuth 2.0 "Web application" credentials in Google Cloud
# Console with an authorized redirect URI of <APP_URL>/auth/callback.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Random secret used to sign the login session cookie, e.g. `python -c "import secrets; print(secrets.token_hex(32))"`.
SESSION_SECRET_KEY=
# Comma-separated list of Google account emails allowed to log in.
ALLOWED_EMAILS=
# Optional: shown as a "request access" mailto link to users who are signed in but not whitelisted.
CONTACT_EMAIL=
